LOCAL_SEARCH_HTTP_HOST_PORT=8765
LOCAL_SEARCH_NOVNC_HOST_PORT=6082

# Proxy for browser traffic. Set to your proxy server URL if needed.
# Example: http://host.docker.internal:18001 or http://192.168.1.10:7890
# Leave empty for direct connection.
BROWSER_PROXY_SERVER=
LAN_PROXY_SERVER=
VISIBLE_BROWSER_PROXY_SERVER=

# Paper API keys (required for paper search/fetch tools)
OPENALEX_API_KEY=
CROSSREF_MAILTO=
UNPAYWALL_EMAIL=

# ChatGPT login (for chatgpt search engine)
CHATGPT_EMAIL=
CHATGPT_PASSWORD=

# noVNC remote browser access (DISABLED by default for security)
# ⚠️ Setting a password enables noVNC on port 6082.
# Use a strong password. Leave empty to keep noVNC disabled.
NOVNC_PASSWORD=

# Security: Optional Bearer Token Authentication
# When set, all endpoints (except /health) require:
#   Authorization: Bearer <your-token-here>
# Leave empty for no authentication (default, for local-only use).
# Recommended when exposing to network/internet.
# Example: MCP_BEARER_TOKEN=my-super-secret-token-123
MCP_BEARER_TOKEN=

# Security: IP Rate Limiting (prevents internal clients from overwhelming the service)
# Default: 100 requests per 60-second window per IP.
# When rate limited, the server returns 429 with Retry-After header.
# AI clients should respect Retry-After to avoid flooding.
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
