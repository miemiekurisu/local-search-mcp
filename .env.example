LOCAL_SEARCH_HTTP_HOST_PORT=8765
LOCAL_SEARCH_NOVNC_HOST_PORT=6082

# Proxy for browser traffic. Set to your proxy server URL if needed.
# Example: http://host.docker.internal:18001 or http://192.168.1.10:7890
# Leave empty for direct connection.
BROWSER_PROXY_SERVER=
LAN_PROXY_SERVER=
VISIBLE_BROWSER_PROXY_SERVER=

# Paper API keys (required for paper search/fetch tools)
OPENALEX_API_KEY=
CROSSREF_MAILTO=
UNPAYWALL_EMAIL=

# ChatGPT login (for chatgpt search engine)
CHATGPT_EMAIL=
CHATGPT_PASSWORD=
