# ─── Host port binding ───────────────────────────────────────────
# MCP HTTP 服务宿主端口（默认 0.0.0.0:8765，所有网卡）
HTTP_LISTEN_HOST=0.0.0.0
HTTP_LISTEN_PORT=8765

# noVNC 宿主端口（默认 127.0.0.1:6082，仅本机访问）
# ⚠️ 改为 0.0.0.0 允许局域网访问，务必设置 NOVNC_PASSWORD
NOVNC_LISTEN_HOST=127.0.0.1
NOVNC_LISTEN_PORT=6082

# ─── Proxy (代理) ─────────────────────────────────────────────────
# Browser HTTP 代理（DuckDuckGo、Google、Bing 等搜索引擎请求）
# 示例: LAN_PROXY_SERVER=http://192.168.1.100:8117
# 留空则直连
LAN_PROXY_SERVER=

# Chromium 浏览器代理（visible browser 的 --proxy-server 参数）
VISIBLE_BROWSER_PROXY_SERVER=

# HTTP 代理配置文件中的代理（proxy_profiles.json 的 "http" profile）
BROWSER_PROXY_SERVER=

# ─── ChatGPT 登录（可选） ──────────────────────────────────────────
CHATGPT_EMAIL=
CHATGPT_PASSWORD=

# ─── 学术论文工具 ──────────────────────────────────────────────────
ENABLE_PAPER_TOOLS=true
OPENALEX_API_KEY=
CROSSREF_MAILTO=
UNPAYWALL_EMAIL=

# ─── noVNC 密码（默认禁用） ────────────────────────────────────────
# ⚠️ 设置密码后会启用 noVNC，请务必使用强密码
# 留空则 noVNC 不会启动，这是安全默认值
NOVNC_PASSWORD=

# ─── 安全配置 ──────────────────────────────────────────────────────
# Bearer Token 认证：设置后所有端点（除 /health）需 Authorization: Bearer <token>
# 公网暴露时必须设置
MCP_BEARER_TOKEN=

# 速率限制：每个 IP 在窗口期内的最大请求数
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ─── 其他可选参数 ──────────────────────────────────────────────────
# 默认时区（get_time 工具，留空则使用服务器本地时区）
TIMEZONE=
